# Supabase (main platform)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# OTP: backend SMS (recommended — no Firebase billing needed)
VITE_OTP_PROVIDER=backend
OTP_PROVIDER=fast2sms
FAST2SMS_API_KEY=

# Alternative OTP provider
# OTP_PROVIDER=msg91
# MSG91_AUTH_KEY=
# MSG91_TEMPLATE_ID=

# Dev-only mock OTP (never use in production)
# OTP_PROVIDER=mock
# OTP_ALLOW_MOCK=true

# Firebase (optional — only if VITE_OTP_PROVIDER=firebase and Blaze billing enabled)
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# FIREBASE_PROJECT_ID=
# FIREBASE_API_KEY=
