{
  "mcpServers": {
    "lovable": {
      "type": "http",
      "url": "https://mcp.lovable.dev",
      "auth": {
        "CLIENT_ID": "YOUR_LOVABLE_CLIENT_ID"
      }
    },
    "firebase": {
      "command": "npx",
      "args": [
        "-y",
        "firebase-tools@latest",
        "mcp",
        "--dir",
        "/absolute/path/to/gigbridge-global",
        "--only",
        "auth,core"
      ]
    }
  }
}
